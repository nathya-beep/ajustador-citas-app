DATABASE_URL="postgresql://user:password@localhost:5432/ajustador_citas"
SESSION_SECRET=""
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
CRON_SECRET=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ----- Email -----
# Remitente que verá el cliente (con SMTP debe ser un remitente verificado).
EMAIL_FROM="InspectPro <tu-correo@gmail.com>"

# Opción GRATIS sin dominio propio (recomendada): SMTP.
# Funciona con SendGrid, Brevo, Gmail (contraseña de aplicación), etc.
# Ejemplo Gmail: host=smtp.gmail.com puerto=587 usuario=tu-correo@gmail.com pass=contraseña-de-aplicacion
# Ejemplo Brevo: host=smtp-relay.brevo.com puerto=587
# Ejemplo SendGrid: host=smtp.sendgrid.net puerto=587 usuario="apikey" pass=<API_KEY>
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""

# Alternativa: Resend (requiere dominio verificado). Si defines esto y no defines SMTP, se usa Resend.
RESEND_API_KEY=""

# ----- SMS / WhatsApp (Twilio, opcional) -----
# Si lo dejas vacío, no se envían SMS (no rompe nada).
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""            # número SMS en E.164, ej. +13055550100
TWILIO_WHATSAPP_FROM=""   # emisor WhatsApp, ej. whatsapp:+14155238886
TWILIO_CHANNEL="sms"      # "sms" o "whatsapp"
